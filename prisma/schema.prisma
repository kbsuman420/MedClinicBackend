// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ClinicStatus {
  pending
  approved
}

enum ActiveStatus {
  active
  closed
}

// 1. Clinic Model
model Clinic {
  id                    String   @id @default(uuid()) 
  owner_doctor_name     String
  gmail                 String       @unique
  password              String       @db.VarChar(255)
  phone                 String       @unique
  speciality            String
  medical_council_reg_no String      @unique
  experience            Int
  qualification         String
  clinic_name           String
  address               String
  city                  String
  consultations_fee     Float        @default(0)
  about_of_clinic       String?

  status                ClinicStatus @default(pending)

  current_active_status ActiveStatus @default(active)

  created_at            DateTime     @default(now())
  updated_at            DateTime     @updatedAt


  appointments Appointment[] @relation("ClinicToAppointments")
  availabilitySlots DoctorAvailabilitySlot[] @relation("ClinicToAvailabilitySlots")

  @@map("clinics")
}


// 3. Patient Model (User)
model Patient {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(255)
  email     String   @unique @db.VarChar(150)
  password  String   @db.VarChar(255)
  phone     String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  appointments Appointment[] @relation("PatientToAppointments")

  @@map("patients")
}

// 4. Appointment Model
model Appointment {
  id              String            @id @default(uuid())
  appointmentDate DateTime          @map("appointment_date")
  status          AppointmentStatus @default(PENDING)
  notes           String?           @db.Text
  patientId       String            @map("patient_id")
  clinicId        String            @map("clinic_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Relations
  patient Patient @relation("PatientToAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  clinic  Clinic  @relation("ClinicToAppointments", fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([clinicId])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// 5. Doctor Availability Slot Model
model DoctorAvailabilitySlot {
  id          String   @id @default(uuid())
  clinicId    String   @map("clinic_id")
  dayOfWeek   Int      @map("day_of_week")
  startTime   String   @map("start_time")
  endTime     String   @map("end_time")
  isAvailable Boolean  @default(true)      @map("is_available")
  createdAt   DateTime @default(now())     @map("created_at")
  updatedAt   DateTime @updatedAt          @map("updated_at")

  // Relations
  clinic Clinic @relation("ClinicToAvailabilitySlots", fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([dayOfWeek])
  @@map("doctor_availability_slots")
}


model EmailVerification {
  id              String   @id @default(uuid())

  gmail           String   @unique

  otp_hash        String
  otp_attempts    Int      @default(0)

  otp_expires_at  DateTime
  last_sent_at    DateTime @default(now())

  verified        Boolean  @default(false)

  locked_until    DateTime?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([gmail])
  @@map("email_verifications")
}
